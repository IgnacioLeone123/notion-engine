# ============================================
# NOTION ENGINE — Variables de Entorno
# ============================================
# Copiá este archivo como .env y completá los valores reales.

# Notion Integration Token (Internal Integration)
# Obtener en: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la página madre donde se inyectan las plantillas
# Formato UUID: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_PAGE_ID=

# ── Cliente LLM ────────────────────────────────────────
# Gratis: Saca una API Key en https://console.groq.com/keys
OPENAI_API_KEY=gsk_pega-tu-api-key-de-groq-aca
OPENAI_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-key-segura-en-produccion
DEBUG=True
